@page "/pois/map"
@using ManagementSystem.Dtos
@using ManagementSystem.Services.IServices
@using Newtonsoft.Json
@inject IPoiClientService PoiService
@inject IJSRuntime JS
@inject IConfiguration Configuration

<div class="row" style="height: 100vh; overflow: hidden;">
    <!-- Full screen responsive -->
    <div class="col-md-4 col-12 list-group" style="max-height: 100%; overflow-y: auto;">
        <!-- List scrollable, full on mobile -->
        @if (pois == null)
        {
            <div class="p-3">Loading...</div>
        }
        else
        {
            @foreach (var p in pois)
            {
                <a class="list-group-item list-group-item-action" @onclick="() => Focus(p)">
                    @p.LocalizedData[0].Name (Range: @p.Range m)
                </a>
            }
        }
    </div>
    <div class="col-md-8 col-12 p-0">
        <!-- Map full width/height -->
        <div id="map" style="height: 100%; width: 100%;"></div>
    </div>
</div>

@code {
    private List<PoiDto>? pois;
    private string mapboxKey;

    protected override async Task OnInitializedAsync()
    {
        mapboxKey = Configuration["MAPBOX_KEY"];
        pois = await PoiService.GetAllPoisAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && pois != null && pois.Count > 0)
        {
            // Thêm token vào pois[0] temp để pass sang JS
            var poisJson = JsonConvert.SerializeObject(pois.Select(p => new { p.Position, p.Range, token = mapboxKey }).ToList());
            await JS.InvokeVoidAsync("initPoiMap", poisJson);
        }
    }

    private async Task Focus(PoiDto poi)
    {
        await JS.InvokeVoidAsync("focusPoi", poi.Position.Lng, poi.Position.Lat, poi.Range);
    }
}