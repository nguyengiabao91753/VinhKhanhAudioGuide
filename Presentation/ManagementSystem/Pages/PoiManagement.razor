@page "/pois"
@using ManagementSystem.Dtos
@using ManagementSystem.Services.IServices
@inject IPoiClientService PoiService
@inject NavigationManager Nav

<h3>POI Management</h3>
<button class="btn btn-primary" @onclick="AddNew">➕ Add POI</button>
<button class="btn btn-secondary" @onclick="ViewAllOnMap">🗺 View All On Map</button>

<table class="table table-striped mt-3">
    <thead>
        <tr>
            <th>Name</th>
            <th>Lat</th>
            <th>Lng</th>
            <th>Range (m)</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var p in pois)
        {
            <tr>
                <td>@p.LocalizedData[0].Name</td>
                <td>@p.Position.Lat</td>
                <td>@p.Position.Lng</td>
                <td>@p.Range</td>
                <td>
                    <button class="btn btn-sm btn-warning" @onclick="() => Edit(p.Id)">Edit</button>
                </td>
            </tr>
        }
    </tbody>
</table>

@code {
    private List<PoiDto> pois = new();

    protected override async Task OnInitializedAsync()
    {
        pois = await PoiService.GetAllPoisAsync() ?? new();
    }

    private void AddNew() => Nav.NavigateTo("/pois/add");
    private void Edit(Guid id) => Nav.NavigateTo($"/pois/edit/{id}");
    private void ViewAllOnMap() => Nav.NavigateTo("/pois/map");
}